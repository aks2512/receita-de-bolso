{
  "expo": {
    "name": "Receita de Bolso",
    "slug": "receita-de-bolso",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "receitadebolso",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.jpg"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EFF1ED"
      },
      "predictiveBackGestureEnabled": false,
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "package": "com.aks2512.receitadebolso"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "O app precisa acessar sua câmera para tirar foto.",
          "photoPermission": "O app precisa acessar suas fotos para escolher uma imagem."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EFF1ED",
          "image": "./assets/images/icon.jpg"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 1
          },
          "androidIntentFilters": ["text/*", "image/*"],
          "iosShareExtensionName": "Salvar Receita"
        }
      ],
      "expo-secure-store",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e4569e77-6eca-4b65-8087-25bda33f705a"
      }
    },
    "owner": "aks2512",
    "updates": {
      "url": "https://u.expo.dev/e4569e77-6eca-4b65-8087-25bda33f705a"
    }
  }
}
